# Normalize line endings to LF in the repo (consistent CI/lint/format across OSes).
* text=auto eol=lf

# Treat binaries as binary — never touch line endings.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.avif binary
*.woff  binary
*.woff2 binary
*.pdf  binary
*.db   binary

# Lockfiles are generated — collapse diffs in review.
package-lock.json -diff
