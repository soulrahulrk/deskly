# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore real secrets, keep the template committed
.env*
!.env.example

# prisma / local database
/prisma/dev.db
/prisma/dev.db-journal
/prisma/*.db
/prisma/*.db-*
/src/generated

# tests / e2e artifacts
/playwright-report
/test-results
/blob-report
/playwright/.cache
/coverage
/test/*.db
/test/*.db-*
/test/test.db

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
