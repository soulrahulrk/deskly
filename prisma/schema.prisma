// Deskly data model — multi-tenant helpdesk.
// Provider is SQLite (zero-setup local dev + reviewer clone); the runtime client
// talks to it through the libSQL driver adapter, so production can point at Turso
// with the same schema. See docs/deployment.md for the Postgres alternative.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────── Tenancy ────────────────────────────────────

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  ticketCounter Int      @default(0) // drives per-org sequential ticket numbers
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users      User[]
  contacts   Contact[]
  tickets    Ticket[]
  tags       Tag[]
  auditLogs  AuditLog[]
  savedViews SavedView[]
}

// ─────────────────────────── Auth.js + app users ────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null for OAuth-only accounts
  role          String    @default("AGENT") // Role enum (string; see lib/constants)
  orgId         String?
  organization  Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  accounts            Account[]
  sessions            Session[]
  assignedTickets     Ticket[]             @relation("TicketAssignee")
  comments            Comment[]
  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// Email verification (gates write access) — stores a hash, never the raw token.
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Single-use, hashed-at-rest password reset token (20-min TTL).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ───────────────────────────────── Domain ───────────────────────────────────

model Contact {
  id        String   @id @default(cuid())
  orgId     String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  email     String
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[]

  @@unique([orgId, email])
  @@index([orgId])
}

model Tag {
  id        String   @id @default(cuid())
  orgId     String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  tickets TicketTag[]

  @@unique([orgId, name])
  @@index([orgId])
}

model Ticket {
  id           String    @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  number       Int // per-org sequential, human-friendly (#1042)
  subject      String
  body         String
  status       String    @default("OPEN") // TicketStatus enum
  priority     String    @default("MEDIUM") // TicketPriority enum
  assigneeId   String?
  assignee     User?     @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  contactId    String
  contact      Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  firstResponseAt DateTime? // first agent reply — powers response-time metric
  resolvedAt      DateTime?
  deletedAt       DateTime? // soft delete (recovery + audit trail)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments Comment[]
  events   TicketEvent[]
  tags     TicketTag[]

  @@unique([orgId, number])
  @@index([orgId, status])
  @@index([orgId, priority])
  @@index([orgId, assigneeId])
  @@index([orgId, createdAt])
  @@index([orgId, deletedAt])
}

model Comment {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body       String
  isInternal Boolean  @default(false) // internal note vs. customer-visible reply
  createdAt  DateTime @default(now())

  @@index([ticketId])
}

model TicketTag {
  ticketId String
  tagId    String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ticketId, tagId])
  @@index([tagId])
}

// Immutable per-ticket timeline (status/priority/assignment changes).
model TicketEvent {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type      String // TicketEventType enum
  data      String? // JSON: { from, to }
  actorId   String?
  createdAt DateTime @default(now())

  @@index([ticketId])
}

// Immutable org-wide audit log — who changed what, when, before → after.
model AuditLog {
  id           String   @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actorId      String?
  actor        User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action       String // AuditAction enum
  entity       String
  entityId     String
  summary      String
  before       String? // JSON snapshot
  after        String? // JSON snapshot
  createdAt    DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([orgId, entity, entityId])
}

model SavedView {
  id           String   @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name         String
  query        String // serialized filter query string
  createdById  String?
  createdAt    DateTime @default(now())

  @@index([orgId])
}
